# ─── Mode ────────────────────────────────────────────────────
# 'org' = multi-agent workspace  |  'agent' = single-agent deployment
NEXT_PUBLIC_XO_MODE=org

# Fixed agent ID for agent-only mode (ignored in org mode)
NEXT_PUBLIC_XO_AGENT_ID=aria

# ─── Backend ─────────────────────────────────────────────────
# Primary backend server URL (sessions, tasks, workspace)
XO_BACKEND_URL=http://localhost:8000

# Optional: separate backend URL for agent mode
# XO_AGENT_BACKEND_URL=http://localhost:8001

# ─── Auth ────────────────────────────────────────────────────
# Secret used to sign agent tokens (xo_ag_{id}_{hmac})
# IMPORTANT: change this in production
XO_SERVER_SECRET=xo-dev-secret-change-me

# ─── Storage ─────────────────────────────────────────────────
# Optional: custom workspace root directories
# XO_STORAGE_ROOT=/path/to/org/workspace
# XO_AGENT_STORAGE_ROOT=/path/to/agent/workspace
